---
layout: null
---
[
  {% assign has_items = false %}
  {% for post in site.posts %}
    {% assign post_search_text = post.subtitle | default: post.excerpt | strip_html | strip_newlines | truncate: 80 %}
    {% if has_items %},{% endif %}
    {
      "title"    : "{{ post.title | escape }}",
      "subtitle" : "【文章】{{ post_search_text | escape }}",
      "tags"     : "{{ post.tags | join: ', ' }}",
      "url"      : "{{ site.baseurl }}{{ post.url }}",
      "date"     : "{{ post.date }}"
    }
    {% assign has_items = true %}
  {% endfor %}
  {% for post in site.series %}
    {% assign series_search_text = post.summary | default: post.subtitle | strip_html | strip_newlines | truncate: 80 %}
    {% if has_items %},{% endif %}
    {
      "title"    : "{{ post.title | escape }}",
      "subtitle" : "【画廊】{{ series_search_text | escape }}",
      "tags"     : "{{ post.tags | join: ', ' }}",
      "url"      : "{{ site.baseurl }}{{ post.url }}",
      "date"     : "{{ post.date }}"
    }
    {% assign has_items = true %}
  {% endfor %}
]
